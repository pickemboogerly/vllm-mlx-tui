# vllm-mlx-tui Configuration Template
# Copy this to .env and adjust as needed

# --- Inference Engine Settings ---
# Binary to use for the MLX server. Default: vllm-mlx
# VLLM_MLX_BIN=vllm-mlx

# Seconds to wait for /v1/models to become reachable after launch. Default: 120
# API_READY_TIMEOUT=120

# --- Networking ---
# Default host for the local server. Default: 120.0.0.1
# VLLM_HOST=127.0.0.1

# Default port for the local server. Default: 8001
# VLLM_PORT=8001

# --- TUI Experience ---
# (Optional) Version override or developer flags
# APP_VERSION=0.1.0-dev
